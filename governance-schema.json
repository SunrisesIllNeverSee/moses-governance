{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MO§E§™ Governed Context Payload",
  "description": "The complete governed payload delivered to agents on every read. This is what makes MO§E§™ different from raw chat — agents receive constitutional orders, not just messages.",
  "type": "object",
  "properties": {
    "constitutional_governance": {
      "type": "object",
      "description": "Active governance configuration",
      "properties": {
        "mode": { "type": "string", "description": "Active governance mode" },
        "mode_constraints": { "type": "array", "items": { "type": "string" }, "description": "Behavioral constraints from active mode" },
        "mode_prohibited": { "type": "array", "items": { "type": "string" }, "description": "Actions prohibited under active mode" },
        "mode_priority": { "type": "string", "description": "Decision priority (security_first, accuracy_first, etc.)" },
        "posture": { "type": "string", "enum": ["SCOUT", "DEFENSE", "OFFENSE"] },
        "posture_behavior": { "type": "string" },
        "posture_transaction_policy": { "type": "string" },
        "posture_constraints": { "type": "array", "items": { "type": "string" } },
        "reasoning_mode": { "type": "string", "enum": ["Deductive", "Inductive", "Abductive", "Analogical", "Critical"] },
        "reasoning_depth": { "type": "string", "enum": ["SHALLOW", "MODERATE", "DEEP"] },
        "response_style": { "type": "string", "enum": ["Direct", "Socratic", "Storytelling", "Visual", "Suggestive", "Empirically Driven"] },
        "output_format": { "type": "string", "enum": ["Conversational", "Document", "Markdown", "Code", "Chart / Visualization", "Spreadsheet"] },
        "narrative_strength": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "required": ["mode", "mode_constraints", "posture", "posture_transaction_policy"]
    },
    "role_assignment": {
      "type": "object",
      "description": "Agent's role in the hierarchy",
      "properties": {
        "role": { "type": "string", "enum": ["Primary", "Secondary", "Observer"] },
        "authority": { "type": "string" },
        "instruction": { "type": "string", "description": "Direct behavioral instruction for this role" },
        "constraints": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["role", "instruction"]
    },
    "user_profile": {
      "type": "object",
      "description": "Operator profile for response calibration",
      "properties": {
        "expertise": { "type": "string", "enum": ["Novice", "Moderate", "Expert"] },
        "interaction_mode": { "type": "string", "enum": ["Fleshing Out", "Walking Through", "Executing"] },
        "domain": { "type": "string" },
        "communication_pref": { "type": "string", "enum": ["Concise", "Explanatory", "Visual", "Narrative"] },
        "goal": { "type": "string" }
      }
    },
    "vault_context": {
      "type": "array",
      "description": "Loaded governance documents injected into context",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "category": { "type": "string", "enum": ["Protocol", "Persona", "Prompt", "Personal", "Professional", "Business"] },
          "content": { "type": "string" }
        }
      }
    },
    "messages": {
      "type": "array",
      "description": "Conversation messages with governance metadata",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "sender": { "type": "string" },
          "text": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "governance_at_send": {
            "type": "object",
            "description": "Governance state when this message was sent",
            "properties": {
              "mode": { "type": "string" },
              "posture": { "type": "string" },
              "role": { "type": "string" }
            }
          }
        }
      }
    },
    "prior_responses": {
      "type": "array",
      "description": "Previous agent responses (included for Secondary and Observer roles)",
      "items": {
        "type": "object",
        "properties": {
          "agent": { "type": "string" },
          "role": { "type": "string" },
          "response": { "type": "string" }
        }
      }
    }
  },
  "required": ["constitutional_governance", "role_assignment", "messages"]
}
