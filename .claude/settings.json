{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(xargs git:*)",
      "Bash(find . -name '* 2.*' -not -path ./.git/* -not -path ./archive/* -delete)",
      "Bash(find . -name '* 2' -type d -not -path ./.git/* -not -path ./archive/* -exec rm -rf {} +)"
    ]
  }
}
